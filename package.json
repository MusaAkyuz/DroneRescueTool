{
  "name": "drone-rescue-tool",
  "version": "1.0.0",
  "description": "Drone video ve telemetri verilerini kullanarak doğada yabancı cisimleri tespit eden taşınabilir görüntü işleme aracı",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "chcp 65001 >nul && electron-vite preview",
    "dev": "chcp 65001 >nul && electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "build:python": "node scripts/build-python.js",
    "postinstall": "electron-builder install-app-deps && node scripts/patch-electron-builder.js",
    "build:unpack": "npm run build:python && npm run build && electron-builder --dir",
    "build:win": "npm run build:python && npm run build && electron-builder --win",
    "build:mac": "npm run build:python && electron-vite build && electron-builder --mac",
    "build:linux": "npm run build:python && electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^10.0.2",
    "eslint-plugin-react": "^7.22.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "postcss": "^8.5.6",
    "prettier": "3.8.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
